# ===== RPC（可选，留空则用链配置里的默认公共 RPC）=====
# 例如 Alchemy / Infura / QuickNode 申请的 key
ALCHEMY_KEY=
INFURA_KEY=

# ===== Telegram Bot =====
# 从 @BotFather 获取
TELEGRAM_BOT_TOKEN=
# 目标 chat id（自己跟 bot 私聊后访问 https://api.telegram.org/bot<TOKEN>/getUpdates 获取）
TELEGRAM_CHAT_ID=

# ===== Bark (iOS 推送) =====
# 仅需设备 key，默认走官方服务器 https://api.day.app/<key>
# 多设备推送：用英文逗号分隔多个 key（如 key1,key2），会并行推送到所有设备
BARK_KEY=
# 自建 Bark 服务器地址（可选，留空用官方）
BARK_SERVER=

# ===== Server酱 / PushPlus (微信推送) =====
# Server酱 SCKEY，https://sct.ftqq.com
SERVERCHAN_KEY=
# 企业微信群机器人 webhook key（即 .../send?key=xxx 中的 xxx）
WECOM_WEBHOOK_KEY=

# ===== 监控参数 =====
# 轮询 cron 表达式，默认每 3 分钟
CRON_EXPRESSION=*/3 * * * *
# 同一仓位同状态重复告警冷却（毫秒），默认 1 小时
ALERT_COOLDOWN_MS=3600000

# ===== 数据库 =====
DB_PATH=./data/app.db

# ===== 币安报价（CEX 价差对比用，可选）=====
# 默认走 https://api.binance.com。国内 VPS 若访问受限，可改用可用域名，如 data-api.binance.vision
BINANCE_HOST=
